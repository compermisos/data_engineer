# 5. Bloque de ejecución principal
if __name__ == "__main__":
    # Nombres de los archivos de entrada y salida
    ARCHIVO_ENTRADA = "access.log"
    ARCHIVO_SALIDA = "logs_procesados.avro"
    
    # IMPORTANTE: Asegúrate de tener un archivo 'access.log' en el mismo directorio
    # antes de ejecutar este script.
    try:
        process_logs_to_avro(ARCHIVO_ENTRADA, ARCHIVO_SALIDA)
    except FileNotFoundError:
        print(f"Error: No se encontró el archivo de entrada '{ARCHIVO_ENTRADA}'. Por favor, créalo o verifica la ruta.")
