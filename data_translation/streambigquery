import os
import apachelogs
from pydantic import BaseModel, Field, IPvAnyAddress
from datetime import datetime
from typing import Optional, List
from google.cloud import bigquery
from google.api_core.exceptions import GoogleAPIError

# 1. Definir el esquema de Pydantic
class ApacheLog(BaseModel):
    ip_address: IPvAnyAddress
    client_identity: Optional[str] = None
    userid: Optional[str] = None
    timestamp: datetime
    method: str
    request_uri: str
    http_version: str
    status_code: int = Field(ge=100, le=599)
    userAgent: Optional[str] = None
    referer: Optional[str] = None
    response_size: Optional[int] = None

# 2. Esquema de BigQuery (Mapeado desde el modelo Pydantic)
bq_schema = [
    bigquery.SchemaField("ip_address", "STRING", mode="REQUIRED"),
    bigquery.SchemaField("client_identity", "STRING", mode="NULLABLE"),
    bigquery.SchemaField("userid", "STRING", mode="NULLABLE"),
    bigquery.SchemaField("timestamp", "TIMESTAMP", mode="REQUIRED"),
    bigquery.SchemaField("method", "STRING", mode="REQUIRED"),
    bigquery.SchemaField("request_uri", "STRING", mode="REQUIRED"),
    bigquery.SchemaField("http_version", "STRING", mode="REQUIRED"),
    bigquery.SchemaField("status_code", "INTEGER", mode="REQUIRED"),
    bigquery.SchemaField("userAgent", "STRING", mode="NULLABLE"),
    bigquery.SchemaField("referer", "STRING", mode="NULLABLE"),
    bigquery.SchemaField("response_size", "INTEGER", mode="NULLABLE"),
]

# 3. Función para parsear los logs
def parse_apachelogs(line: str) -> Optional[ApacheLog]:
    try:
        log_format = '%h %l %u %t "%r" %s %b "%{Referer}i" "%{User-Agent}i" "%u"'
        parser = apachelogs.LogParser(log_format)
        log_line_data = parser.parse(line)
        
        request_elements = log_line_data.request_line.split()
        method = request_elements[0] if len(request_elements) > 0 else "-"
        request_uri = request_elements[1] if len(request_elements) > 1 else "-"
        http_version = request_elements[2] if len(request_elements) > 2 else "-"
        
        return ApacheLog(
            ip_address=log_line_data.remote_host,
            client_identity=log_line_data.remote_logname,
            userid=log_line_data.remote_user,
            timestamp=log_line_data.request_time,
            method=method,
            request_uri=request_uri,
            http_version=http_version,
            status_code=log_line_data.status,
            userAgent=log_line_data.headers_in.get("User-Agent"),
            referer=log_line_data.headers_in.get("Referer"),
            response_size=log_line_data.bytes_sent
        )
    except Exception as e:
        print(f"Error al parsear la línea: {e}")
        return None

# 4. Crear tabla en BigQuery si no existe
def ensure_table_exists(client: bigquery.Client, table_id: str):
    try:
        client.get_table(table_id)
        print(f"La tabla {table_id} ya existe.")
    except Exception:
        print(f"Creando la tabla {table_id}...")
        table = bigquery.Table(table_id, schema=bq_schema)
        client.create_table(table)
        print("Tabla creada exitosamente.")

# 5. Inyectar registros por Stream API
def stream_to_bigquery(client: bigquery.Client, table_id: str, rows_to_insert: List[dict]):
    if not rows_to_insert:
        return

    try:
        errors = client.insert_rows_json(table_id, rows_to_insert)
        if not errors:
            print(f"  -> Se insertaron {len(rows_to_insert)} filas con éxito.")
        else:
            print(f"  -> Se encontraron errores al insertar: {errors}")
    except GoogleAPIError as e:
        print(f"Error de API al intentar insertar datos: {e}")

# 6. Procesar el archivo y coordinar el streaming
def process_logs_and_stream(input_file_path: str, project_id: str, dataset_id: str, table_name: str, batch_size: int = 500):
    client = bigquery.Client(project=project_id)
    table_id = f"{project_id}.{dataset_id}.{table_name}"
    
    ensure_table_exists(client, table_id)
    
    print(f"\nIniciando procesamiento de '{input_file_path}'...")
    
    batch = []
    total_processed = 0

    with open(input_file_path, 'r', encoding='utf-8') as file:
        for line in file:
            line = line.strip()
            if not line:
                continue
                
            parsed_log = parse_apachelogs(line)
            if parsed_log:
                # Convertimos a JSON asegurando que las fechas e IPs sean strings compatibles con BQ
                log_dict = parsed_log.model_dump(mode='json')
                batch.append(log_dict)
                total_processed += 1

                # Cuando el lote alcanza el tamaño deseado, lo enviamos a BQ
                if len(batch) >= batch_size:
                    stream_to_bigquery(client, table_id, batch)
                    batch.clear() # Vaciamos el lote actual

    # Insertar cualquier registro restante que no haya llenado el último lote
    if batch:
        stream_to_bigquery(client, table_id, batch)

    print(f"\nProceso finalizado. Total de registros procesados e insertados: {total_processed}")
from google.cloud import bigquery

def generar_esquema_bq(modelo: type[BaseModel]) -> list[bigquery.SchemaField]:
    # Mapeo de tipos de Python/Pydantic a BigQuery
    bq_type_mapping = {
        str: "STRING",
        int: "INTEGER",
        float: "FLOAT",
        bool: "BOOLEAN",
        datetime: "TIMESTAMP",
        IPvAnyAddress: "STRING"
    }

    schema = []
    
    for nombre_campo, field_info in modelo.model_fields.items():
        tipo_anotacion = field_info.annotation
        
        es_opcional = get_origin(tipo_anotacion) is Union and type(None) in get_args(tipo_anotacion)
        tipo_base = get_args(tipo_anotacion)[0] if es_opcional else tipo_anotacion
        
        # Obtener el tipo BQ correspondiente
        bq_type = bq_type_mapping.get(tipo_base, "STRING")
        
        # Si es opcional, el modo es NULLABLE, de lo contrario REQUIRED
        bq_mode = "NULLABLE" if es_opcional or not field_info.is_required() else "REQUIRED"
        
        schema.append(bigquery.SchemaField(nombre_campo, bq_type, mode=bq_mode))
        
    return schema

